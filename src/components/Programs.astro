  },
  {
    title: 'Coding School',
    grades: 'All Ages',
    description: 'Learn Python, Java, Scratch, Web Development, and more with hands-on project-based lessons.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
    color: 'secondary',
