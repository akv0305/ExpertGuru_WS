---
const steps = [
  {
    number: '01',
    title: 'Book a Free Demo',
    description: 'Fill out a quick form or call us. We\'ll schedule a free session at a time that works for you.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
  },
  {
    number: '02',
    title: 'Get Matched with a Tutor',
    description: 'We match your child with an expert tutor based on subject, learning style, and personality fit.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
  },
  {
    number: '03',
    title: 'Start Learning',
    description: 'Your child begins 1-on-1 sessions from home. The Education Manager tracks progress and keeps you informed.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    number: '04',
    title: 'Watch Grades Improve',
    description: 'Monthly progress reports, parent-tutor conferences, and a clear path to academic success.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>`,
  },
];
---

<section class="section-padding bg-white">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-14">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">How It Works</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
        Getting Started Is <span class="gradient-text">Simple</span>
      </h2>
      <p class="text-gray-600 text-lg">
        From your first call to measurable grade improvement — here's what to expect.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="relative text-center group">
          {/* Connector line */}
          {index < steps.length - 1 && (
            <div class="hidden lg:block absolute top-10 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-px bg-linear-to-r from-primary/40 to-primary/10"></div>
          )}

          {/* Step circle */}
          <div class="relative z-10 w-20 h-20 mx-auto mb-6 bg-linear-to-br from-primary to-primary-700 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-primary/20 group-hover:shadow-xl group-hover:shadow-primary/30 group-hover:-translate-y-1 transition-all">
            <Fragment set:html={step.icon} />
          </div>

          {/* Step number */}
          <div class="text-xs font-bold text-primary/40 uppercase tracking-widest mb-2">Step {step.number}</div>

          <h3 class="text-lg font-bold text-gray-900 mb-2">{step.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="/contact" class="btn-primary">
        Get Started — It's Free
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
