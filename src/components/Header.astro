        { href: '/ap-statistics', label: 'AP Statistics' },
        { href: '/ap-computers', label: 'AP Computer Science' },
        { href: '/ap-biology', label: 'AP Biology' },
        { href: '/ap-chemistry', label: 'AP Chemistry' },
        { href: '/ap-physics-1-2', label: 'AP Physics 1 & 2' },
        { href: '/ap-physics-c-mechanics', label: 'AP Physics C' },
