---
import { siteConfig } from '../data/config';

const stats = [
  { value: '500+', label: 'Families Trust Us' },
  { value: '4.9/5', label: 'Student Rating' },
  { value: '50+', label: 'Subjects Covered' },
];

const cards = [
  {
    title: 'K–12 Tutoring',
    desc: 'All subjects, all grade levels',
    iconColor: 'text-primary-300',
    bgColor: 'bg-primary/20',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
  },
  {
    title: 'AP & IB Prep',
    desc: 'Score 4s and 5s with expert help',
    iconColor: 'text-secondary-300',
    bgColor: 'bg-secondary/20',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`,
  },
  {
    title: 'SAT / ACT Prep',
    desc: 'Proven strategies, higher scores',
    iconColor: 'text-green-300',
    bgColor: 'bg-green-500/20',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>`,
  },
  {
    title: 'Coding School',
    desc: 'Python, Java, Web Dev & more',
    iconColor: 'text-orange-300',
    bgColor: 'bg-orange-500/20',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>`,
  },
];
---

<section class="relative overflow-hidden bg-linear-to-br from-gray-900 via-gray-900 to-primary-900">
  <!-- Ambient glow -->
  <div class="absolute inset-0">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/15 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-secondary/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="container-custom relative z-10 py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left — Copy -->
      <div class="text-center lg:text-left">
        <!-- Urgency badge -->
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8">
          <span class="flex h-2 w-2 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <span class="text-white/90 text-sm font-medium">Free Demo Classes — Limited Spots This Week</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] mb-6 text-white">
          Your Child Deserves
          <span class="block mt-2 bg-linear-to-r from-primary-300 via-purple-300 to-secondary-300 bg-clip-text text-transparent">
            Better Grades
          </span>
        </h1>

        <p class="text-lg lg:text-xl text-white/60 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          1-on-1 online tutoring with top 1% tutors. Personalized learning plans for K–12, AP, IB, SAT, ACT, and coding — from the comfort of home.
        </p>

        <!-- Feature pills -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mb-10">
          {['Same Tutor Every Session', 'Dedicated Education Manager', 'Free Demo Class'].map((f) => (
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/10 rounded-full text-sm text-white/80">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-400 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {f}
            </span>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-4 mb-12">
          <a href={siteConfig.app.bookDemo} class="group inline-flex items-center gap-2 bg-primary hover:bg-primary-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5">
            Book Free Demo
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/services" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/20 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all">
            Explore Programs
          </a>
        </div>

        <!-- Stats -->
        <div class="flex justify-center lg:justify-start gap-8 lg:gap-12">
          {stats.map((stat) => (
            <div class="text-center lg:text-left">
              <div class="text-2xl lg:text-3xl font-bold text-white">{stat.value}</div>
              <div class="text-sm text-white/40 mt-1">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right — Card grid -->
      <div class="relative hidden lg:block">
        <div class="grid grid-cols-2 gap-4">
          {cards.map((card, i) => (
            <div class={`bg-white/10 backdrop-blur-md border border-white/10 rounded-2xl p-6 hover:bg-white/15 transition-all hover:-translate-y-1 ${i % 2 !== 0 ? 'mt-8' : ''}`}>
              <div class={`w-12 h-12 ${card.bgColor} rounded-xl flex items-center justify-center mb-4 ${card.iconColor}`}>
                <Fragment set:html={card.icon} />
              </div>
              <h3 class="text-white font-semibold mb-1">{card.title}</h3>
              <p class="text-white/50 text-sm">{card.desc}</p>
            </div>
          ))}
        </div>

        <!-- Floating testimonial -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-2xl p-5 max-w-[280px]">
          <div class="flex items-center gap-1 mb-2">
            {[1,2,3,4,5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-700 text-sm italic">"My son's math grade went from C to A in just 3 months!"</p>
          <p class="text-gray-500 text-xs mt-2">— Nitya M., Parent</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave divider -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 60V30C240 0 480 0 720 30C960 60 1200 60 1440 30V60H0Z" fill="white"/>
    </svg>
  </div>
</section>
