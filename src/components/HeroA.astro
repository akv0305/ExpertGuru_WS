---
import { siteConfig } from '../data/config';
---

<section class="relative overflow-hidden bg-linear-to-br from-gray-50 via-white to-primary/5 pt-8 pb-16 md:pt-12 md:pb-20">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-72 h-72 bg-secondary/5 rounded-full blur-3xl"></div>
  </div>

  <div class="container-custom relative z-10">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Left Column -->
      <div>
        <!-- Experience Badge -->
        <div class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-full px-4 py-2 mb-6 shadow-sm">
          <div class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            <span class="text-sm font-semibold text-gray-900">30+ Years</span>
          </div>
          <span class="text-xs text-gray-500">in Education & Tutoring</span>
        </div>

        <!-- Headline -->
        <h1 class="text-3xl md:text-4xl lg:text-4xl font-bold text-gray-900 leading-tight mb-5">
          From Struggling to <span class="gradient-text">Confident High Scorers</span> — Powered by Expert Guru's
        </h1>

        <!-- Description -->
        <p class="text-lg text-gray-600 leading-relaxed mb-8 max-w-xl">
          1-on-1 online tutoring with the same expert tutor every session. Personalized learning plans for K–12, AP, IB & SAT / ACT.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <a href={siteConfig.app.bookDemo} class="btn-primary text-center">
            Book Free Demo Class
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/#programs" class="btn-outline text-center">
            Explore Programs
          </a>
        </div>
      </div>

      <!-- Right Column — Image -->
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-primary/10">
          <img 
            src="/hero-student.webp" 
            alt="Student smiling during an online tutoring session with Expert Guru" 
            width="800" 
            height="600" 
            class="w-full h-auto object-cover"
          />
        </div>

        <!-- Floating Card: Results -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg border border-gray-100 p-4 flex items-center gap-3 animate-float">
          <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
          </div>
          <div>
            <div class="font-bold text-gray-900 text-sm">Grades Improved</div>
            <div class="text-xs text-gray-500">95% of students see results</div>
          </div>
        </div>

        <!-- Floating Card: Signup Credit -->
        <div class="absolute -top-4 -right-4 bg-white rounded-xl shadow-lg border border-gray-100 p-4 flex items-center gap-3 animate-float-delayed">
          <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <div class="font-bold text-gray-900 text-sm">Sign Up & Get $10</div>
            <div class="text-xs text-gray-500">Free credit on your account</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  @keyframes float-delayed {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
  .animate-float-delayed {
    animation: float-delayed 4s ease-in-out infinite 1s;
  }
</style>
