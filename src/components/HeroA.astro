---
import { siteConfig } from '../data/config';
---

<section class="relative bg-linear-to-b from-white to-gray-50 overflow-hidden">
  <div class="container-custom py-16 lg:py-24">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left — Copy -->
      <div>
        <!-- Trust badge -->
        <div class="inline-flex items-center gap-2 bg-primary/5 border border-primary/15 rounded-full px-4 py-2 mb-6">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm font-medium text-gray-700">4.9/5 from 500+ families</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-bold leading-[1.1] mb-6 text-gray-900">
          Watch Your Child Go from Struggling to
          <span class="gradient-text"> Confident</span>
        </h1>

        <p class="text-lg lg:text-xl text-gray-600 mb-8 max-w-xl leading-relaxed">
          1-on-1 online tutoring with the same expert tutor every session. Personalized learning plans for K–12, AP, IB, SAT, ACT & Coding.
        </p>

        <!-- Trust points -->
        <div class="flex flex-wrap gap-x-6 gap-y-3 mb-10">
          {['Top 1% vetted tutors', 'Free demo class', 'Same tutor every time'].map((point) => (
            <span class="flex items-center gap-2 text-sm text-gray-600">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              {point}
            </span>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a href={siteConfig.app.bookDemo} class="group inline-flex items-center gap-2 bg-primary hover:bg-primary-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5">
            Book Free Demo Class
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/services" class="inline-flex items-center gap-2 border-2 border-gray-300 hover:border-primary text-gray-700 hover:text-primary px-8 py-4 rounded-xl font-semibold text-lg transition-all">
            Explore Programs
          </a>
        </div>
      </div>

      <!-- Right — Image -->
      <div class="relative">
        <div class="relative rounded-3xl overflow-hidden shadow-2xl shadow-primary/10">
          <!-- Placeholder: Replace src with your generated image -->
          <!-- <div class="aspect-[4/3] bg-linear-to-br from-primary/10 via-secondary/10 to-primary/5 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-24 h-24 mx-auto mb-6 bg-primary/10 rounded-2xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
                </svg>
              </div> 
              <p class="text-gray-500 text-sm font-medium">Hero Image Placeholder</p>
              <p class="text-gray-400 text-xs mt-1">Replace with generated student image</p>
            </div>
          </div> -->
          <!-- When you have the image, replace the div above with: -->
          <img
            src="/hero-student.webp"
            alt="Student smiling during an online tutoring session with Expert Guru" 
            class="w-full h-auto object-cover" 
            width="800" 
            height="600" 
            loading="eager" 
          />
        </div>

        <!-- Floating stats card -->
        <div class="absolute -bottom-4 -left-4 lg:-left-8 bg-white rounded-2xl shadow-xl border border-gray-100 p-4 flex items-center gap-3">
          <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <div class="text-sm font-bold text-gray-900">Grades Improved</div>
            <div class="text-xs text-gray-500">95% of students see results</div>
          </div>
        </div>

        <!-- Floating rating card -->
        <div class="absolute -top-4 -right-4 lg:-right-8 bg-white rounded-2xl shadow-xl border border-gray-100 p-4 flex items-center gap-3">
          <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-500" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </div>
          <div>
            <div class="text-sm font-bold text-gray-900">4.9 / 5.0</div>
            <div class="text-xs text-gray-500">500+ reviews</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
