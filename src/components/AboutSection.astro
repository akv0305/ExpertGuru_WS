---
const highlights = [
  {
    title: 'Tailored SAT/ACT Coaching',
    description: 'We use smart algorithms and performance data to customize strategies and target instruction to your needs.',
  },
  {
    title: 'Learning Experts by Your Side',
    description: 'Our tutors rank in the top 1% and come from prestigious universities. They bring proven techniques and real results to every session.',
  },
];
---

<section class="section-padding bg-gradient-to-br from-gray-50 to-white">
  <div class="container-custom">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Who we are</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-2 mb-6">
          Excellence in education with a
          <span class="gradient-text"> personalized approach</span>
        </h2>
        <p class="text-gray-600 mb-8 leading-relaxed">
          With years of expertise in SAT/ACT prep and academic tutoring, we&apos;re committed to helping students reach their potential. Our proven strategies and personalized support lead to measurable results and academic success.
        </p>

        <div class="space-y-6">
          {highlights.map((item) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">{item.title}</h3>
                <p class="text-gray-600 text-sm">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right Content - Stats/Image -->
      <div class="relative">
        <div class="bg-gradient-to-br from-primary to-secondary rounded-3xl p-8 text-white">
          <div class="grid grid-cols-2 gap-8">
            <div class="text-center">
              <div class="text-4xl font-bold mb-2">1%</div>
              <div class="text-white/80 text-sm">Top Tutors</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold mb-2">100%</div>
              <div class="text-white/80 text-sm">Satisfaction</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold mb-2">24/7</div>
              <div class="text-white/80 text-sm">Support</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold mb-2">1:1</div>
              <div class="text-white/80 text-sm">Personalized</div>
            </div>
          </div>
        </div>

        <!-- Floating Card -->
        <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-6 max-w-xs">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-gray-900">Risk-Free</div>
              <div class="text-sm text-gray-500">Money-back guarantee</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
