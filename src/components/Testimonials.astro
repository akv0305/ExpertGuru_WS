---
const testimonials = [
  {
    name: 'Nitya Mateti',
    role: 'Student',
    text: 'ExpertGuru helped me improve significantly in math and reading. The tutors explained concepts clearly, and the practice tests closely matched the real exam. The program is well-structured and effective.',
    rating: 5,
    subject: 'Math & Reading',
  },
  {
    name: 'Srividya Matta',
    role: 'Parent',
    text: 'The AP prep is really good — the clear lessons and practice materials boosted my son\'s confidence. The explanations are easy to follow, and it makes AP exams feel much less daunting.',
    rating: 5,
    subject: 'AP Prep',
  },
  {
    name: 'Sai Akshay Chimakurty',
    role: 'Student',
    text: 'Expert Guru helped me improve in areas I struggled with in Math. The teachers provide helpful materials and tips to boost ACT scores, and they are very friendly and supportive.',
    rating: 5,
    subject: 'Math & ACT',
  },
];
---

<section class="section-padding bg-linear-to-b from-white to-gray-50">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-14">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Testimonials</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
        Real Results from <span class="gradient-text">Real Families</span>
      </h2>
      <p class="text-gray-600 text-lg">
        Don't just take our word for it — hear from students and parents who've experienced the Expert Guru difference.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((testimonial) => (
        <div class="bg-white border border-gray-200 rounded-2xl p-7 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1 transition-all">
          <!-- Rating Stars -->
          <div class="flex items-center gap-2 mb-5">
            <div class="flex gap-0.5">
              {Array.from({ length: testimonial.rating }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-xs font-medium text-gray-400 bg-gray-100 rounded-full px-2 py-0.5">{testimonial.subject}</span>
          </div>

          <!-- Quote -->
          <blockquote class="text-gray-600 leading-relaxed mb-6">
            "{testimonial.text}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-5 border-t border-gray-100">
            <div class="w-10 h-10 bg-linear-to-br from-primary to-secondary rounded-full flex items-center justify-center text-white font-bold text-sm">
              {testimonial.name.charAt(0)}
            </div>
            <div>
              <div class="font-semibold text-gray-900 text-sm">{testimonial.name}</div>
              <div class="text-xs text-gray-500">{testimonial.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Social proof bar -->
    <div class="mt-12 bg-primary/5 border border-primary/10 rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-center gap-4 text-center">
      <div class="flex -space-x-2">
        {['N', 'S', 'A', 'R', 'P'].map((initial) => (
          <div class="w-8 h-8 bg-linear-to-br from-primary to-secondary rounded-full flex items-center justify-center text-white text-xs font-bold border-2 border-white">
            {initial}
          </div>
        ))}
      </div>
      <p class="text-gray-700 font-medium">
        Trusted by <span class="text-primary font-bold">500+ families</span> across the US, India, and beyond
      </p>
    </div>
  </div>
</section>
