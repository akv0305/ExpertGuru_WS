---
const apSubjects = [
  'AP Precalculus',
  'AP Biology',
  'AP Environmental Science',
  'AP Physics C & Mechanics',
  'AP Physics 1 & 2',
  'AP Chemistry',
];

const ibSubjects = [
  'IB Math',
  'IB Biology',
  'IB Chemistry',
  'IB Physics',
];

const featuredLinks = [
  { href: '/terms-and-conditions', label: 'Terms and Conditions' },
  { href: '/privacy-policy', label: 'Privacy Policy' },
];
---

<footer class="bg-gray-900 text-gray-300">
  <!-- Top Banner -->
  <div class="bg-gradient-to-r from-primary to-secondary py-8">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="text-xl md:text-2xl font-bold text-white">Unlock Knowledge, Unlock Success</h3>
          <p class="text-white/80">Learn Without Limits</p>
        </div>
        <a href="/contact" class="bg-white text-primary px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
          Get Started Today
        </a>
      </div>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="container-custom py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Logo & About -->
      <div class="lg:col-span-1">
        <img src="/logo.png" alt="Expert Guru" class="h-16 w-auto mb-4 bg-white p-2 rounded-lg" />
        <p class="text-sm text-gray-400 mb-4">
          Learn Anywhere, Succeed Everywhere - Empowering You with Knowledge that Lasts a Lifetime.
        </p>
        <div class="flex gap-4">
          <a href="https://facebook.com" target="_blank" rel="noopener" class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.77,7.46H14.5v-1.9c0-.9.6-1.1,1-1.1h3V.5h-4.33C10.24.5,9.5,3.44,9.5,5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4Z"/></svg>
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener" class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12,2.16c3.2,0,3.58.01,4.85.07,3.25.15,4.77,1.69,4.92,4.92.06,1.27.07,1.65.07,4.85s-.01,3.58-.07,4.85c-.15,3.23-1.66,4.77-4.92,4.92-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85C2.38,3.92,3.9,2.38,7.15,2.23,8.42,2.17,8.8,2.16,12,2.16ZM12,0C8.74,0,8.33.01,7.05.07c-4.27.2-6.78,2.71-6.98,6.98C.01,8.33,0,8.74,0,12s.01,3.67.07,4.95c.2,4.27,2.71,6.78,6.98,6.98,1.28.06,1.69.07,4.95.07s3.67-.01,4.95-.07c4.27-.2,6.78-2.71,6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.27-2.71-6.78-6.98-6.98C15.67.01,15.26,0,12,0Zm0,5.84A6.16,6.16,0,1,0,18.16,12,6.16,6.16,0,0,0,12,5.84ZM12,16a4,4,0,1,1,4-4A4,4,0,0,1,12,16ZM18.41,4.15a1.44,1.44,0,1,0,1.44,1.44A1.44,1.44,0,0,0,18.41,4.15Z"/></svg>
          </a>
        </div>
      </div>

      <!-- AP Subjects -->
      <div>
        <h4 class="text-white font-semibold mb-4">AP Subjects</h4>
        <ul class="space-y-2">
          {apSubjects.map((subject) => (
            <li>
              <span class="text-sm text-gray-400 hover:text-white transition-colors cursor-default">
                {subject}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- IB Subjects -->
      <div>
        <h4 class="text-white font-semibold mb-4">IB Subjects</h4>
        <ul class="space-y-2">
          {ibSubjects.map((subject) => (
            <li>
              <span class="text-sm text-gray-400 hover:text-white transition-colors cursor-default">
                {subject}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Featured Links & Address -->
      <div>
        <h4 class="text-white font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2 mb-6">
          {featuredLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        
        <h4 class="text-white font-semibold mb-2">Address</h4>
        <p class="text-sm text-gray-400">
          Plot No 2/P and 3/P, Venkusa Estates, Kowkoor, Secunderabad, Telangana-500010, India.
        </p>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="container-custom py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-500">
        <p>&copy; {new Date().getFullYear()} Expert Guru, All rights reserved.</p>
        <div class="flex gap-4">
          <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
          <a href="/terms-and-conditions" class="hover:text-white transition-colors">Terms</a>
        </div>
      </div>
    </div>
  </div>
</footer>
