---
const currentYear = new Date().getFullYear();

const programs = [
  { href: '/elementary-school', label: 'Elementary School (K-5)' },
  { href: '/middle-high-school', label: 'Middle & High School' },
  { href: '/coding-school', label: 'Coding School' },
  { href: '/college-tutoring', label: 'College Tutoring' },
  { href: '/test-prep', label: 'Test Prep' },
];

const apSubjects = [
  { href: '/ap-subjects#ap-calculus-ab', label: 'AP Calculus AB' },
  { href: '/ap-subjects#ap-calculus-bc', label: 'AP Calculus BC' },
  { href: '/ap-subjects#ap-precalculus', label: 'AP Precalculus' },
  { href: '/ap-subjects#ap-statistics', label: 'AP Statistics' },
  { href: '/ap-subjects#ap-computers', label: 'AP Computer Science' },
  { href: '/ap-subjects#ap-biology', label: 'AP Biology' },
  { href: '/ap-subjects#ap-chemistry', label: 'AP Chemistry' },
  { href: '/ap-subjects#ap-physics-1-2', label: 'AP Physics 1 & 2' },
];

const ibAndTestPrep = [
  { href: '/ib', label: 'IB Program Overview' },
  { href: '/ib#ib-biology', label: 'IB Biology' },
  { href: '/ib#ib-chemistry', label: 'IB Chemistry' },
  { href: '/ib#ib-physics', label: 'IB Physics' },
  { href: '/ib#ib-math', label: 'IB Math (AA & AI)' },
  { href: '/sat', label: 'SAT Prep' },
  { href: '/act', label: 'ACT Prep' },
  { href: '/psat', label: 'PSAT Prep' },
];

const company = [
  { href: '/about', label: 'About Us' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/testimonials', label: 'Testimonials' },
  { href: '/contact', label: 'Contact Us' },
  { href: '/international-teachers', label: 'Become a Tutor' },
];

const legal = [
  { href: '/privacy-policy', label: 'Privacy Policy' },
  { href: '/terms-and-conditions', label: 'Terms & Conditions' },
  { href: '/cancellation-and-refund-policy', label: 'Refund Policy' },
  { href: '/shipping-policy', label: 'Shipping Policy' },
];

const trustPoints = [
  { icon: 'tutor', text: 'Top 1% Vetted Tutors' },
  { icon: 'match', text: 'Same Tutor Every Session' },
  { icon: 'demo', text: 'Free Demo Class' },
  { icon: 'support', text: 'Dedicated Education Manager' },
];
---

<!-- ===== PRE-FOOTER CTA BANNER ===== -->
<section class="relative overflow-hidden bg-linear-to-r from-primary-700 via-primary to-secondary">
  <!-- Background decoration -->
  <div class="absolute inset-0">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-white/5 rounded-full blur-3xl"></div>
  </div>

  <div class="container-custom relative z-10 py-14 md:py-16">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
      <div class="text-center lg:text-left max-w-2xl">
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-tight">
          Ready to See Your Child's Grades Improve?
        </h2>
        <p class="text-white/80 mt-3 text-base md:text-lg">
          Book a free demo class today. No commitment, no pressure — just see the difference expert 1-on-1 tutoring makes.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row items-center gap-4 shrink-0">
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary font-bold rounded-xl shadow-lg hover:shadow-xl hover:bg-gray-50 transition-all text-base">
          Book Free Demo Class
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href="mailto:info@expertguru.net" class="inline-flex items-center gap-2 px-6 py-4 text-white/90 font-medium rounded-xl border border-white/20 hover:bg-white/10 transition-colors text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          info@expertguru.net
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===== TRUST STRIP ===== -->
<div class="bg-gray-950 border-b border-gray-800/50">
  <div class="container-custom py-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
      {trustPoints.map((point) => (
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
            {point.icon === 'tutor' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            )}
            {point.icon === 'match' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            )}
            {point.icon === 'demo' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            )}
            {point.icon === 'support' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            )}
          </div>
          <span class="text-sm font-medium text-gray-300">{point.text}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ===== MAIN FOOTER ===== -->
<footer class="bg-gray-950 text-gray-400" role="contentinfo">
  <div class="container-custom pt-14 pb-8">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 lg:gap-6">

      <!-- Brand Column — spans 2 cols on lg -->
      <div class="col-span-2 md:col-span-3 lg:col-span-2 lg:pr-8">
        <a href="/" class="inline-block mb-5">
          <img src="/eglogo.png" alt="Expert Guru" class="h-22 w-auto bg-white p-1.5 rounded-lg" loading="lazy" />
        </a>
        <p class="text-sm leading-relaxed mb-6 max-w-sm">
          Expert Guru provides personalized 1-on-1 online tutoring with top educators. We help students from elementary through college build confidence, improve grades, and achieve academic success.
        </p>

        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a href="https://www.instagram.com/expertguru_/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-gray-800 rounded-lg flex items-center justify-center text-gray-400 hover:bg-primary hover:text-white transition-all" aria-label="Follow Expert Guru on Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12,2.16c3.2,0,3.58.01,4.85.07,3.25.15,4.77,1.69,4.92,4.92.06,1.27.07,1.65.07,4.85s-.01,3.58-.07,4.85c-.15,3.23-1.66,4.77-4.92,4.92-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85C2.38,3.92,3.9,2.38,7.15,2.23,8.42,2.17,8.8,2.16,12,2.16ZM12,0C8.74,0,8.33.01,7.05.07c-4.27.2-6.78,2.71-6.98,6.98C.01,8.33,0,8.74,0,12s.01,3.67.07,4.95c.2,4.27,2.71,6.78,6.98,6.98,1.28.06,1.69.07,4.95.07s3.67-.01,4.95-.07c4.27-.2,6.78-2.71,6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.27-2.71-6.78-6.98-6.98C15.67.01,15.26,0,12,0Zm0,5.84A6.16,6.16,0,1,0,18.16,12,6.16,6.16,0,0,0,12,5.84ZM12,16a4,4,0,1,1,4-4A4,4,0,0,1,12,16ZM18.41,4.15a1.44,1.44,0,1,0,1.44,1.44A1.44,1.44,0,0,0,18.41,4.15Z"/></svg>
          </a>
          <a href="https://www.facebook.com/expertguru" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-gray-800 rounded-lg flex items-center justify-center text-gray-400 hover:bg-primary hover:text-white transition-all" aria-label="Follow Expert Guru on Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.77,7.46H14.5v-1.9c0-.9.6-1.1,1-1.1h3V.5h-4.33C10.24.5,9.5,3.44,9.5,5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4Z"/></svg>
          </a>
          <a href="https://www.youtube.com/@expertguru" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-gray-800 rounded-lg flex items-center justify-center text-gray-400 hover:bg-primary hover:text-white transition-all" aria-label="Expert Guru on YouTube">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/expertguru" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-gray-800 rounded-lg flex items-center justify-center text-gray-400 hover:bg-primary hover:text-white transition-all" aria-label="Expert Guru on LinkedIn">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <!-- Programs -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Programs</h4>
        <ul class="space-y-2.5">
          {programs.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- AP Subjects -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">AP Subjects</h4>
        <ul class="space-y-2.5">
          {apSubjects.slice(0, 8).map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
          <li>
            <a href="/ap-subjects" class="text-sm text-primary-400 hover:text-primary-300 font-medium transition-colors">View all →</a>
          </li>
        </ul>
      </div>

      <!-- IB & Test Prep -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">IB & Test Prep</h4>
        <ul class="space-y-2.5">
          {ibAndTestPrep.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Company</h4>
        <ul class="space-y-2.5 mb-6">
          {company.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>

        <h4 class="text-white font-semibold text-sm mb-3">Contact</h4>
        <ul class="space-y-2.5">
          <li>
            <a href="mailto:info@expertguru.net" class="text-sm hover:text-white transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              info@expertguru.net
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Address -->
    <div class="mt-10 pt-8 border-t border-gray-800/50">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
        <div class="flex items-start gap-2 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 mt-0.5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <span>#302, 3rd Floor, Meridian Plaza, Ameerpet, Hyderabad - 500016, Telangana, India</span>
        </div>
        <div class="flex items-center gap-2 text-xs text-gray-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-yellow-500" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          Rated <strong class="text-gray-300">4.9/5</strong> by 500+ families
        </div>
      </div>
    </div>
  </div>

  <!-- ===== BOTTOM BAR ===== -->
  <div class="border-t border-gray-800/50">
    <div class="container-custom py-5">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-gray-500">
        <p>&copy; {currentYear} Expert Guru - A Brand from DG Tutor. All rights reserved.</p>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
          {legal.map((link) => (
            <a href={link.href} class="hover:text-gray-300 transition-colors">{link.label}</a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>
