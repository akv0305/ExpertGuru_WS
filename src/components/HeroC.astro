---
import { siteConfig } from '../data/config';

const stats = [
  { value: '500+', label: 'Students Tutored' },
  { value: '50+', label: 'Subjects Covered' },
  { value: '4.9/5', label: 'Parent Rating' },
  { value: '100%', label: 'Satisfaction' },
];
---

<section class="relative overflow-hidden bg-linear-to-b from-primary/3 via-white to-white">
  <!-- Soft background shapes -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-primary/5 rounded-full blur-[100px]"></div>
  </div>

  <div class="container-custom relative z-10 pt-16 lg:pt-24 pb-8">
    <!-- Centered text block -->
    <div class="text-center max-w-4xl mx-auto">
      <!-- Trust line -->
      <div class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-full px-5 py-2.5 mb-8 shadow-sm">
        <div class="flex gap-0.5">
          {[1,2,3,4,5].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span class="text-sm font-medium text-gray-700">Trusted by 500+ families across the US & India</span>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] mb-6 text-gray-900">
        Expert Tutoring That
        <span class="gradient-text"> Actually Works</span>
      </h1>

      <p class="text-lg lg:text-xl text-gray-600 max-w-2xl mx-auto mb-8 leading-relaxed">
        1-on-1 online sessions with top 1% tutors. Same tutor every time. Personalized plans for K–12, AP, IB, SAT, ACT & Coding.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap justify-center gap-4 mb-6">
        <a href={siteConfig.app.bookDemo} class="group inline-flex items-center gap-2 bg-primary hover:bg-primary-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5">
          Book Free Demo
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#how-it-works" class="inline-flex items-center gap-2 border-2 border-gray-300 hover:border-primary text-gray-700 hover:text-primary px-8 py-4 rounded-xl font-semibold text-lg transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          See How It Works
        </a>
      </div>

      <!-- Micro trust -->
      <p class="text-sm text-gray-500 mb-12">No credit card required · Free trial · Cancel anytime</p>
    </div>

    <!-- Hero visual — image placeholder with overlapping cards -->
    <div class="relative max-w-5xl mx-auto">
      <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-gray-900/10 border border-gray-200">
        <!-- Placeholder: Replace with generated image -->
        <div class="aspect-16/7 bg-linear-to-br from-primary/5 via-secondary/5 to-primary/10 flex items-center justify-center">
          <div class="text-center p-8">
            <div class="flex items-center justify-center gap-4 mb-4">
              <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                </svg>
              </div>
              <div class="w-16 h-16 bg-secondary/10 rounded-2xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
                </svg>
              </div>
              <div class="w-16 h-16 bg-green-500/10 rounded-2xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342" />
                </svg>
              </div>
            </div>
            <p class="text-gray-500 text-sm font-medium">Hero Image Placeholder</p>
            <p class="text-gray-400 text-xs mt-1">Replace with a wide image of students learning online</p>
          </div>
        </div>
        <!-- When you have the image: -->
        <img src="/images/hero-wide.webp" alt="Students learning online with Expert Guru tutors" class="w-full h-auto object-cover" width="1200" height="525" loading="eager" />
        
      </div>

      <!-- Floating feature cards overlapping the image -->
      <div class="absolute -bottom-6 left-4 right-4 lg:left-12 lg:right-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          {stats.map((stat) => (
            <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-4 text-center">
              <div class="text-xl lg:text-2xl font-bold text-primary">{stat.value}</div>
              <div class="text-xs text-gray-500 mt-0.5">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Spacer for the overlapping stats -->
    <div class="h-12"></div>
  </div>
</section>
