---
const faqs = [
  {
    question: 'How do you ensure online tutoring is as effective as in-person tutoring?',
    answer: 'We use a one-on-one approach with a live tutor on a shared digital whiteboard. Each student has a dedicated Education Manager who creates a customized learning plan. This personalized, distraction-free environment ensures focused attention and consistent progress.',
  },
  {
    question: 'Are your tutors qualified and experienced?',
    answer: 'Yes. Most of our tutors hold a Master\'s degree in their subject, and all are trained in our tutoring methodology. We match your child with the same tutor for every session to build a strong, consistent learning relationship.',
  },
  {
    question: 'How do you track my child\'s progress?',
    answer: 'We provide a detailed monthly progress report via email outlining your child\'s academic growth and areas for improvement. We also schedule regular parent-tutor conferences every 30 to 45 days to discuss progress and adjust the learning plan.',
  },
  {
    question: 'What equipment does my child need?',
    answer: 'Your child will need a PC or Mac, a broadband internet connection, a headset with a microphone, and a digital writing pad. The writing pad lets the student and tutor work together on the shared whiteboard in real-time.',
  },
  {
    question: 'How many hours of tutoring are recommended?',
    answer: 'Most students benefit from at least two hours of one-on-one tutoring per week. The recommended hours depend on your child\'s individual needs and academic goals, which your Education Manager will help determine.',
  },
  {
    question: 'How much does tutoring cost?',
    answer: 'Our pricing is based on monthly packages and varies by subject and number of hours. Contact our enrollment team for detailed pricing or visit our pricing page to explore options that fit your budget.',
  },
  {
    question: 'Can I try a class before committing?',
    answer: 'Absolutely! We offer a free demo class so you can experience our tutoring approach firsthand. There\'s no obligation — it\'s a chance to see the quality of our teaching and find the right fit for your child.',
  },
];
---

<section class="section-padding bg-white">
  <div class="container-custom">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Left — Header -->
      <div class="lg:sticky lg:top-32">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">FAQ</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
          Questions? <span class="gradient-text">We've Got Answers</span>
        </h2>
        <p class="text-gray-600 text-lg mb-8">
          Everything you need to know about Expert Guru's tutoring services. Can't find what you're looking for? Reach out to us directly.
        </p>
        <a href="/contact" class="btn-primary">
          Ask Us Anything
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </a>
      </div>

      <!-- Right — Accordion -->
      <div class="space-y-3">
        {faqs.map((faq, index) => (
          <details class="group bg-gray-50 border border-gray-200 rounded-xl overflow-hidden open:bg-white open:border-primary/20 open:shadow-sm transition-all" open={index === 0}>
            <summary class="flex items-center justify-between p-5 cursor-pointer list-none font-semibold text-gray-900 hover:text-primary transition-colors">
              <span class="pr-4 text-sm lg:text-base">{faq.question}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 shrink-0 group-open:rotate-180 group-open:text-primary transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-gray-600 text-sm leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
