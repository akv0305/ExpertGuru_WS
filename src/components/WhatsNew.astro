---
const offerings = [
  { name: 'Competitive Exams', icon: '🏆' },
  { name: 'School Tuition', icon: '🏫' },
  { name: 'Courses for Kids', icon: '👧' },
  { name: 'One-to-One Tutoring', icon: '👨‍🏫' },
  { name: 'Study Materials', icon: '📚' },
];
---

<section class="section-padding bg-gradient-to-br from-gray-50 to-white">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">What&apos;s New on Expert Guru</span>
    </div>

    <!-- Offerings Grid -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      {offerings.map((offering) => (
        <div class="card text-center hover:scale-105 transition-transform cursor-pointer border border-gray-100">
          <div class="text-4xl mb-3">{offering.icon}</div>
          <h3 class="font-semibold text-gray-800 text-sm">{offering.name}</h3>
        </div>
      ))}
    </div>

    <!-- CTA Section -->
    <div class="mt-16 grid md:grid-cols-2 gap-8">
      <div class="bg-gradient-to-br from-primary to-primary-700 rounded-2xl p-8 text-white">
        <h3 class="text-xl font-bold mb-3">Learn Anywhere, Succeed Everywhere</h3>
        <p class="text-white/80 mb-6">
          Learn anytime, anywhere with access to resources, interactive lessons, and expert guidance beyond classroom limits.
        </p>
        <a href="/services" class="inline-flex items-center bg-white text-primary px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
          Discover More
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="bg-gradient-to-br from-secondary to-accent rounded-2xl p-8 text-white">
        <h3 class="text-xl font-bold mb-3">Inspired Students, Inspired Results</h3>
        <p class="text-white/80 mb-6">
          Empowering Learners with Motivation and Guidance to Achieve their Best.
        </p>
        <a href="/contact" class="inline-flex items-center bg-white text-secondary px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
          Get Started
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Call Support -->
    <div class="mt-12 bg-white rounded-2xl shadow-lg p-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Have a question? Call us right now</h3>
        <p class="text-gray-600">Our support team is available to help you.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="mailto:info@expertguru.net" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email Support
        </a>
        <a href="/contact" class="btn-outline">
          Contact Us
        </a>
      </div>
    </div>
  </div>
</section>
