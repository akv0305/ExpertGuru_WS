---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/config';
import ContactForm from '../components/ContactForm.astro';

const testimonials = [
  {
    name: 'Nitya Mateti',
    role: 'Student',
    text: 'ExpertGuru helped me improve significantly in math and reading. The tutors explained concepts clearly, and the practice tests closely matched the real exam. Overall, the program is well-structured and effective.',
    rating: 5,
    subject: 'Math & Reading',
  },
  {
    name: 'Andrew Manoj Rajan',
    role: 'Student',
    text: "What sets this course apart is its focus and clarity. Practice questions mirror the real SAT, helping me spot patterns, manage time, and avoid traps. The instructors also explain why answers are correct, not just what they are.",
    rating: 5,
    subject: 'SAT Prep',
  },
  {
    name: 'Srividya Matta',
    role: 'Parent',
    text: "The AP prep is really good — the clear lessons and practice materials boosted my son's confidence. The explanations are easy to follow, and it makes AP exams feel much less daunting.",
    rating: 5,
    subject: 'AP Prep',
  },
  {
    name: 'Reddy Shoda',
    role: 'Student',
    text: "Expert Guru is excellent for SAT prep. The teachers prepare students diligently, and I've seen huge improvement in my skills. They also care about students' overall well-being.",
    rating: 5,
    subject: 'SAT Prep',
  },
  {
    name: 'Anushka Tiwari',
    role: 'Student',
    text: "I've been with Expert Guru since October and have improved significantly on my SAT practice tests. The tutors are supportive and explain question types clearly, making it a great place to prepare.",
    rating: 5,
    subject: 'SAT Prep',
  },
  {
    name: 'Sai Akshay Chimakurty',
    role: 'Student',
    text: 'Expert Guru helped me improve in areas I struggled with in Math. The teachers provide helpful materials and tips to boost ACT scores, and they are very friendly and supportive.',
    rating: 5,
    subject: 'Math & ACT',
  },
];

const stats = [
  { value: '500+', label: 'Families Served' },
  { value: '4.9/5', label: 'Average Rating' },
  { value: '95%', label: 'See Grade Improvement' },
  { value: '50+', label: 'Subjects Covered' },
];
---

<Layout title="Testimonials — Real Results from Real Families" description="Read what students and parents say about Expert Guru's 1-on-1 online tutoring. 500+ families trust us with a 4.9/5 rating.">

  <!-- Hero -->
  <section class="relative bg-linear-to-b from-primary/5 to-white py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px]"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Testimonials</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mt-3 mb-6 text-gray-900">
          Real Results from <span class="gradient-text">Real Families</span>
        </h1>
        <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto">
          Don't just take our word for it — hear from students and parents who've experienced the Expert Guru difference.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="bg-white pb-8">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto -mt-6">
        {stats.map((stat) => (
          <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 text-center">
            <div class="text-2xl md:text-3xl font-bold text-primary">{stat.value}</div>
            <div class="text-sm text-gray-600 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Grid -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {testimonials.map((testimonial) => (
          <div class="bg-gray-50 border border-gray-200 rounded-2xl p-7 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1 transition-all">
            <!-- Rating Stars -->
            <div class="flex items-center gap-2 mb-5">
              <div class="flex gap-0.5">
                {Array.from({ length: testimonial.rating }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <span class="text-xs font-medium text-gray-400 bg-gray-100 rounded-full px-2 py-0.5">{testimonial.subject}</span>
            </div>

            <!-- Quote -->
            <blockquote class="text-gray-600 leading-relaxed mb-6 text-sm">
              "{testimonial.text}"
            </blockquote>

            <!-- Author -->
            <div class="flex items-center gap-3 pt-5 border-t border-gray-200">
              <div class="w-10 h-10 bg-linear-to-br from-primary to-secondary rounded-full flex items-center justify-center text-white font-bold text-sm">
                {testimonial.name.charAt(0)}
              </div>
              <div>
                <div class="font-semibold text-gray-900 text-sm">{testimonial.name}</div>
                <div class="text-xs text-gray-500">{testimonial.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Social proof bar -->
      <div class="mt-14 bg-primary/5 border border-primary/10 rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-center gap-4 text-center max-w-3xl mx-auto">
        <div class="flex -space-x-2">
          {['N', 'A', 'S', 'R', 'T'].map((initial) => (
            <div class="w-8 h-8 bg-linear-to-br from-primary to-secondary rounded-full flex items-center justify-center text-white text-xs font-bold border-2 border-white">
              {initial}
            </div>
          ))}
        </div>
        <p class="text-gray-700 font-medium">
          Trusted by <span class="text-primary font-bold">500+ families</span> across the US, India, and beyond
        </p>
      </div>
    </div>
  </section>

  <!-- Why Families Trust Us -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Why Families <span class="gradient-text">Trust Us</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {[
          { title: 'Measurable Improvement', desc: '95% of our students see measurable grade improvement within the first month of tutoring.' },
          { title: 'Consistent Support', desc: 'The same tutor every session means your child builds a real relationship and learns faster.' },
          { title: 'Transparent Communication', desc: 'Monthly progress reports, parent-tutor conferences, and a dedicated Education Manager keep you informed.' },
        ].map((item) => (
          <div class="bg-white border border-gray-200 rounded-2xl p-8 text-center hover:border-primary/30 hover:shadow-lg transition-all">
            <div class="w-12 h-12 mx-auto mb-4 bg-primary/10 rounded-xl flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactForm title="Join 500+ Happy Families" subtitle="Book a free demo class and see why parents and students love Expert Guru." />

</Layout>
