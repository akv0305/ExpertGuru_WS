---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/config';
import ContactForm from '../components/ContactForm.astro';

const subjects = [
  {
    id: 'ap-calculus-ab',
    title: 'AP Calculus AB',
    description: 'Master limits, derivatives, integrals, and the Fundamental Theorem of Calculus with expert guidance designed to earn a 4 or 5 on exam day.',
    topics: ['Limits & continuity', 'Differentiation', 'Applications of derivatives', 'Integration', 'Differential equations'],
  },
  {
    id: 'ap-calculus-bc',
    title: 'AP Calculus BC',
    description: 'Go beyond AB with parametric equations, polar coordinates, series, and advanced integration techniques for a top AP score.',
    topics: ['All AB topics', 'Parametric & polar', 'Sequences & series', 'Advanced integration', 'Taylor polynomials'],
  },
  {
    id: 'ap-precalculus',
    title: 'AP Precalculus',
    description: 'Build the algebraic and trigonometric foundation needed for success in AP Calculus and college-level math.',
    topics: ['Polynomial functions', 'Rational functions', 'Exponential & logarithmic', 'Trigonometric functions', 'Polar functions'],
  },
  {
    id: 'ap-statistics',
    title: 'AP Statistics',
    description: 'Learn to collect, analyze, and draw conclusions from data. Our tutors cover every AP Statistics topic with real-world applications.',
    topics: ['Exploring data', 'Sampling & experiments', 'Probability', 'Inference', 'Regression analysis'],
  },
  {
    id: 'ap-computers',
    title: 'AP Computer Science',
    description: 'Master Java programming, object-oriented design, algorithms, and data structures to ace the AP CS A exam.',
    topics: ['Java fundamentals', 'Object-oriented programming', 'Data structures', 'Algorithms', 'Recursion'],
  },
  {
    id: 'ap-biology',
    title: 'AP Biology',
    description: 'From molecular biology to ecology, our tutors help you understand complex biological systems and prepare for the rigorous AP exam.',
    topics: ['Biochemistry', 'Cell biology', 'Genetics & evolution', 'Ecology', 'Body systems'],
  },
  {
    id: 'ap-chemistry',
    title: 'AP Chemistry',
    description: 'Conquer atomic structure, thermodynamics, kinetics, and equilibrium with expert tutors who make AP Chemistry approachable.',
    topics: ['Atomic structure', 'Bonding', 'Thermodynamics', 'Kinetics', 'Equilibrium'],
  },
  {
    id: 'ap-environmental-science',
    title: 'AP Environmental Science',
    description: 'Explore ecosystems, biodiversity, pollution, and sustainability. Our tutors connect AP Environmental Science to real-world issues.',
    topics: ['Ecosystems & biodiversity', 'Population ecology', 'Land & water use', 'Energy & pollution', 'Global change'],
  },
  {
    id: 'ap-physics-1-2',
    title: 'AP Physics 1 & 2',
    description: 'Build conceptual understanding of mechanics, waves, electricity, and thermodynamics with algebra-based problem-solving.',
    topics: ['Kinematics', 'Forces & Newton\'s laws', 'Energy & momentum', 'Waves & optics', 'Electricity & circuits'],
  },
  {
    id: 'ap-physics-c-mechanics',
    title: 'AP Physics C: Mechanics',
    description: 'Master calculus-based mechanics — from Newton\'s laws to rotational dynamics — for engineering and physics-bound students.',
    topics: ['Kinematics', 'Newton\'s laws (calculus)', 'Work & energy', 'Momentum', 'Rotation & oscillations'],
  },
  {
    id: 'ap-physics-c-em',
    title: 'AP Physics C: Electricity & Magnetism',
    description: 'Tackle electrostatics, circuits, magnetic fields, and electromagnetic induction with rigorous calculus-based tutoring.',
    topics: ['Electrostatics', 'Conductors & capacitors', 'Electric circuits', 'Magnetic fields', 'Electromagnetic induction'],
  },
  {
    id: 'ap-english-language',
    title: 'AP English Language & Composition',
    description: 'Develop rhetorical analysis, argumentation, and synthesis skills to write persuasive essays and earn a top AP English Language score.',
    topics: ['Rhetorical analysis', 'Argumentation', 'Synthesis essays', 'Close reading', 'Prose style'],
  },
  {
    id: 'ap-english-literature',
    title: 'AP English Literature & Composition',
    description: 'Analyze poetry, prose, and drama at a college level. Our tutors help you develop literary analysis skills for the AP Lit exam.',
    topics: ['Poetry analysis', 'Prose fiction analysis', 'Drama & theater', 'Literary argumentation', 'Close reading strategies'],
  },
];
---

<Layout title="AP Subject Tutoring — Score 4s and 5s with Expert Tutors" description="Expert 1-on-1 AP tutoring for 13 AP subjects. Calculus, Chemistry, Physics, Biology, English, Computer Science & more. $20/hr. Free demo class.">

  <!-- Hero -->
  <section class="relative bg-linear-to-b from-primary/5 to-white py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px]"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-flex items-center gap-2 bg-primary/10 text-primary font-semibold text-sm uppercase tracking-wider px-4 py-1.5 rounded-full mb-6">
          13 AP Subjects · $20/hr
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mt-3 mb-6 text-gray-900">
          Score 4s and 5s with <span class="gradient-text">Expert AP Tutoring</span>
        </h1>
        <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto mb-8">
          Our AP tutors know the exam inside and out. Get 1-on-1 support tailored to the AP curriculum, with real practice problems and proven strategies to maximize your score.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={siteConfig.app.bookDemo} class="group inline-flex items-center gap-2 bg-primary hover:bg-primary-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5">
            Book Free AP Demo
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/pricing" class="inline-flex items-center gap-2 border-2 border-gray-300 hover:border-primary text-gray-700 hover:text-primary px-8 py-4 rounded-xl font-semibold text-lg transition-all">
            View Pricing
          </a>
        </div>
        <p class="text-sm text-gray-500 mt-4"><strong class="text-gray-700">$20/hr</strong> (₹1,820) · Free demo class · Same tutor every session</p>
      </div>
    </div>
  </section>

  <!-- All AP Subjects Grid -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">All AP Subjects</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
          Choose Your <span class="gradient-text">AP Subject</span>
        </h2>
        <p class="text-gray-600 text-lg">Click any subject to learn more about what we cover. Every AP course includes exam-focused strategy and practice.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {subjects.map((subject) => (
          <div id={subject.id} class="bg-gray-50 border border-gray-200 rounded-2xl p-7 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all scroll-mt-24">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-primary/10 text-primary text-xs font-bold px-2.5 py-1 rounded-full">AP</span>
              <h3 class="text-lg font-bold text-gray-900">{subject.title}</h3>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{subject.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {subject.topics.map((topic) => (
                <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">{topic}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why AP Tutoring with Expert Guru -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <span class="text-primary font-semibold text-sm uppercase tracking-wider">The Expert Guru Advantage</span>
          <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
            Why Our Students Score <span class="gradient-text">4s and 5s</span>
          </h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { title: 'AP Exam Specialists', desc: 'Our tutors have deep AP exam knowledge — they teach the content and the test-taking strategies that earn top scores.' },
            { title: 'College Board Aligned', desc: 'Every session follows the official College Board curriculum and uses AP-style practice problems and past exam questions.' },
            { title: 'Personalized Pacing', desc: "Whether you're starting fresh or reviewing before the exam, we create a study plan that fits your timeline and goals." },
          ].map((item) => (
            <div class="bg-white border border-gray-200 rounded-2xl p-8 text-center hover:border-primary/30 hover:shadow-lg transition-all">
              <div class="w-12 h-12 mx-auto mb-4 bg-primary/10 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactForm title="Book a Free AP Tutoring Demo" subtitle="See how our AP specialists can help you score a 4 or 5 — no commitment, no cost." />

</Layout>
