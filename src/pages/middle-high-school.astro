---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/config';
import ContactForm from '../components/ContactForm.astro';

const subjects = [
  {
    id: 'algebra',
    title: 'Algebra',
    description: 'From linear equations to quadratics, our tutors break down algebraic concepts into clear, logical steps that build real understanding.',
    topics: ['Linear equations', 'Inequalities', 'Polynomials', 'Quadratic functions', 'Systems of equations'],
  },
  {
    id: 'geometry',
    title: 'Geometry',
    description: 'Master shapes, proofs, and spatial reasoning with visual, hands-on tutoring that makes geometry click.',
    topics: ['Angles & lines', 'Triangles & polygons', 'Circles', 'Area & volume', 'Geometric proofs'],
  },
  {
    id: 'calculus',
    title: 'Calculus',
    description: 'Prepare for AP-level work or master high school calculus concepts with expert guidance through limits, derivatives, and integrals.',
    topics: ['Limits & continuity', 'Derivatives', 'Integrals', 'Applications', 'Pre-calculus foundations'],
  },
  {
    id: 'trigonometry',
    title: 'Trigonometry',
    description: 'Conquer trig functions, identities, and applications with tutors who make abstract concepts concrete.',
    topics: ['Trig functions', 'Identities & equations', 'Graphs of trig functions', 'Right triangle applications', 'Unit circle'],
  },
  {
    id: 'statistics',
    title: 'Statistics',
    description: 'Learn to analyze data, understand probability, and draw conclusions with our statistics tutoring program.',
    topics: ['Data analysis', 'Probability', 'Distributions', 'Hypothesis testing', 'Regression'],
  },
  {
    id: 'integrated-math',
    title: 'Integrated Math (1, 2 & 3)',
    description: 'For students in integrated math programs, our tutors cover the blended curriculum of algebra, geometry, and statistics in each course level.',
    topics: ['Integrated Math 1', 'Integrated Math 2', 'Integrated Math 3', 'Cross-topic problem solving'],
  },
  {
    id: 'biology',
    title: 'Biology',
    description: 'Explore the living world from cells to ecosystems. Our tutors make complex biological concepts engaging and memorable.',
    topics: ['Cell biology', 'Genetics & heredity', 'Evolution', 'Ecology', 'Human body systems'],
  },
  {
    id: 'chemistry',
    title: 'Chemistry',
    description: 'From atomic structure to chemical reactions, our tutors help students understand the why behind every equation.',
    topics: ['Atomic structure', 'Chemical bonding', 'Stoichiometry', 'Acids & bases', 'Thermochemistry'],
  },
  {
    id: 'physics',
    title: 'Physics',
    description: 'Master mechanics, electricity, and waves with tutors who connect physics to real-world examples students can relate to.',
    topics: ['Motion & forces', 'Energy & work', 'Waves & sound', 'Electricity & magnetism', 'Optics'],
  },
  {
    id: 'earth-science',
    title: 'Earth Science',
    description: 'Understand our planet — from rocks and minerals to weather patterns and plate tectonics — with engaging, visual tutoring.',
    topics: ['Geology & minerals', 'Weather & climate', 'Plate tectonics', 'Oceans & water cycle', 'Astronomy basics'],
  },
  {
    id: 'life-science',
    title: 'Life Science',
    description: 'Bridge the gap between elementary science and biology with our life science tutoring for middle school students.',
    topics: ['Living organisms', 'Ecosystems', 'Cells & body systems', 'Heredity', 'Adaptations'],
  },
  {
    id: 'grammar',
    title: 'Grammar',
    description: 'Strengthen writing and communication skills with grammar tutoring that covers everything from sentence structure to advanced composition.',
    topics: ['Sentence structure', 'Parts of speech', 'Punctuation & mechanics', 'Essay writing', 'Literary analysis'],
  },
  {
    id: 'reading-comprehension',
    title: 'Reading Comprehension',
    description: 'Improve critical reading skills for literature, informational texts, and standardized tests with targeted practice and strategy.',
    topics: ['Close reading', 'Inference & analysis', 'Vocabulary in context', 'Text structure', 'Summarization'],
  },
];

const mathSubjects = subjects.filter(s => ['algebra', 'geometry', 'calculus', 'trigonometry', 'statistics', 'integrated-math'].includes(s.id));
const scienceSubjects = subjects.filter(s => ['biology', 'chemistry', 'physics', 'earth-science', 'life-science'].includes(s.id));
const elaSubjects = subjects.filter(s => ['grammar', 'reading-comprehension'].includes(s.id));
---

<Layout title="Middle & High School Tutoring (6-12) — All Subjects" description="Expert 1-on-1 online tutoring for middle and high school students. Algebra, biology, chemistry, physics, and more. Starting at $18/hr. Free demo class.">

  <!-- Hero -->
  <section class="relative bg-linear-to-b from-primary/5 to-white py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px]"></div>
      <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-secondary/5 rounded-full blur-[80px]"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-flex items-center gap-2 bg-primary/10 text-primary font-semibold text-sm uppercase tracking-wider px-4 py-1.5 rounded-full mb-6">
          Grades 6–12
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mt-3 mb-6 text-gray-900">
          Excel in Every Subject with <span class="gradient-text">Expert Tutoring</span>
        </h1>
        <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto mb-8">
          From algebra to physics, our 1-on-1 tutors help middle and high school students build confidence, improve grades, and prepare for college-level work.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={siteConfig.app.bookDemo} class="group inline-flex items-center gap-2 bg-primary hover:bg-primary-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5">
            Book Free Demo Class
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/pricing" class="inline-flex items-center gap-2 border-2 border-gray-300 hover:border-primary text-gray-700 hover:text-primary px-8 py-4 rounded-xl font-semibold text-lg transition-all">
            View Pricing
          </a>
        </div>
        <p class="text-sm text-gray-500 mt-4">Starting at <strong class="text-gray-700">$18/hr</strong> · Free demo class · Same tutor every session</p>
      </div>
    </div>
  </section>

  <!-- Math Subjects -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Mathematics</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
          Math <span class="gradient-text">Subjects</span>
        </h2>
        <p class="text-gray-600 text-lg">From foundational algebra to advanced calculus, our math tutors make complex concepts clear and achievable.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {mathSubjects.map((subject) => (
          <div id={subject.id} class="bg-gray-50 border border-gray-200 rounded-2xl p-7 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all scroll-mt-24">
            <h3 class="text-lg font-bold text-gray-900 mb-2">{subject.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{subject.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {subject.topics.map((topic) => (
                <span class="text-xs bg-primary/5 text-primary-700 px-2.5 py-1 rounded-full font-medium">{topic}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Science Subjects -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Sciences</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
          Science <span class="gradient-text">Subjects</span>
        </h2>
        <p class="text-gray-600 text-lg">Our science tutors bring real-world examples into every lesson, making biology, chemistry, and physics engaging.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {scienceSubjects.map((subject) => (
          <div id={subject.id} class="bg-white border border-gray-200 rounded-2xl p-7 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all scroll-mt-24">
            <h3 class="text-lg font-bold text-gray-900 mb-2">{subject.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{subject.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {subject.topics.map((topic) => (
                <span class="text-xs bg-primary/5 text-primary-700 px-2.5 py-1 rounded-full font-medium">{topic}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ELA Subjects -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">English Language Arts</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
          English & <span class="gradient-text">Reading</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {elaSubjects.map((subject) => (
          <div id={subject.id} class="bg-gray-50 border border-gray-200 rounded-2xl p-7 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all scroll-mt-24">
            <h3 class="text-lg font-bold text-gray-900 mb-2">{subject.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{subject.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {subject.topics.map((topic) => (
                <span class="text-xs bg-primary/5 text-primary-700 px-2.5 py-1 rounded-full font-medium">{topic}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Expert Guru -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14">
          <span class="text-primary font-semibold text-sm uppercase tracking-wider">Why Expert Guru</span>
          <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
            Why Students <span class="gradient-text">Succeed with Us</span>
          </h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { title: 'Same Tutor', desc: 'Consistency builds understanding. Your child works with the same tutor every session.' },
            { title: 'School Textbook', desc: "We teach from your child's exact textbook and curriculum — not generic worksheets." },
            { title: 'Progress Reports', desc: 'Monthly reports and parent-tutor conferences keep you in the loop.' },
            { title: 'Education Manager', desc: 'A dedicated coordinator handles scheduling, tracks progress, and communicates with you.' },
          ].map((item) => (
            <div class="bg-white border border-gray-200 rounded-2xl p-6 text-center hover:border-primary/30 hover:shadow-lg transition-all">
              <div class="w-10 h-10 mx-auto mb-3 bg-primary/10 rounded-lg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <h3 class="font-bold text-gray-900 mb-1">{item.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactForm title="Book a Free Middle/High School Demo" subtitle="See how our tutors help students build confidence and improve grades — no commitment required." />

</Layout>
