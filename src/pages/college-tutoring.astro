---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/config';
import ContactForm from '../components/ContactForm.astro';

const subjects = [
  {
    id: 'college-english',
    title: 'College English',
    description: 'Strengthen academic writing, critical analysis, and literature interpretation skills needed for college-level English courses.',
    topics: ['Essay writing', 'Literary analysis', 'Research papers', 'MLA/APA citation', 'Critical reading'],
  },
  {
    id: 'college-math',
    title: 'College Math',
    description: 'From college algebra to multivariable calculus, our tutors help with the math courses that challenge even strong students.',
    topics: ['College algebra', 'Calculus I, II & III', 'Linear algebra', 'Discrete math', 'Differential equations'],
  },
  {
    id: 'college-chemistry',
    title: 'College Chemistry',
    description: 'Navigate general chemistry and organic chemistry with expert guidance on concepts, problem-solving, and lab preparation.',
    topics: ['General chemistry', 'Organic chemistry', 'Stoichiometry', 'Thermodynamics', 'Lab report writing'],
  },
  {
    id: 'college-biology',
    title: 'College Biology',
    description: 'Get support with introductory biology, microbiology, anatomy, and other college-level bio courses.',
    topics: ['General biology', 'Microbiology', 'Anatomy & physiology', 'Molecular biology', 'Ecology'],
  },
  {
    id: 'college-physics',
    title: 'College Physics',
    description: 'Master mechanics, electromagnetism, thermodynamics, and modern physics with tutors experienced in college-level instruction.',
    topics: ['Classical mechanics', 'Electromagnetism', 'Thermodynamics', 'Optics & waves', 'Modern physics'],
  },
  {
    id: 'college-statistics',
    title: 'College Statistics',
    description: 'From intro stats to advanced statistical methods, our tutors help with probability, inference, and data analysis for any major.',
    topics: ['Descriptive statistics', 'Probability', 'Hypothesis testing', 'Regression analysis', 'Statistical software'],
  },
  {
    id: 'college-genetics',
    title: 'Genetics',
    description: 'Understand inheritance, molecular genetics, genomics, and genetic analysis with expert-level tutoring for college genetics courses.',
    topics: ['Mendelian genetics', 'Molecular genetics', 'Population genetics', 'Genomics', 'Genetic analysis'],
  },
];
---

<Layout title="College Tutoring — STEM, English & More" description="Expert 1-on-1 online tutoring for college students. Math, Chemistry, Biology, Physics, Statistics, Genetics & English. $25/hr. Free demo.">

  <!-- Hero -->
  <section class="relative bg-linear-to-b from-primary/5 to-white py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px]"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-flex items-center gap-2 bg-primary/10 text-primary font-semibold text-sm uppercase tracking-wider px-4 py-1.5 rounded-full mb-6">
          College Level · $25/hr
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mt-3 mb-6 text-gray-900">
          College-Level Tutoring with <span class="gradient-text">Expert Academics</span>
        </h1>
        <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto mb-8">
          College courses move fast. Our tutors bring advanced expertise in STEM, English, and more — providing the 1-on-1 support that lecture halls can't offer.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={siteConfig.app.bookDemo} class="group inline-flex items-center gap-2 bg-primary hover:bg-primary-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all shadow-lg shadow-primary/25">
            Book Free College Demo
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/pricing" class="inline-flex items-center gap-2 border-2 border-gray-300 hover:border-primary text-gray-700 hover:text-primary px-8 py-4 rounded-xl font-semibold text-lg transition-all">
            View Pricing
          </a>
        </div>
        <p class="text-sm text-gray-500 mt-4"><strong class="text-gray-700">$25/hr</strong> (₹2,552) · Free demo class · Expert-level tutors</p>
      </div>
    </div>
  </section>

  <!-- College Subjects Grid -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">College Subjects</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
          Subjects <span class="gradient-text">We Cover</span>
        </h2>
        <p class="text-gray-600 text-lg">Our college tutors hold advanced degrees and have experience teaching at the university level.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {subjects.map((subject) => (
          <div id={subject.id} class="bg-gray-50 border border-gray-200 rounded-2xl p-7 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all scroll-mt-24">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">College</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{subject.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{subject.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {subject.topics.map((topic) => (
                <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">{topic}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why College Tutoring -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Why Students Choose Expert Guru for <span class="gradient-text">College</span>
          </h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { title: 'Advanced Expertise', desc: "Our college tutors hold Master's or doctoral degrees. They've taught at the university level and understand what professors expect." },
            { title: 'Flexible Scheduling', desc: 'College life is busy. Book sessions around your schedule — evenings, weekends, and across time zones.' },
            { title: 'Exam & Assignment Help', desc: 'From midterm prep to final exams, lab reports to research papers — we provide targeted support when you need it most.' },
          ].map((item) => (
            <div class="bg-white border border-gray-200 rounded-2xl p-8 text-center hover:border-primary/30 hover:shadow-lg transition-all">
              <div class="w-12 h-12 mx-auto mb-4 bg-primary/10 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" viewBox="0 0 20 20" fill="currentColor"><path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.547l1.607.688a3 3 0 002.346 0l1.607-.688v3.547a9.026 9.026 0 00-2.3 1.638z" /></svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactForm title="Book a Free College Tutoring Demo" subtitle="Experience expert-level 1-on-1 tutoring for your college courses — no commitment required." />

</Layout>
