---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/config';
import ContactForm from '../components/ContactForm.astro';

const sections = [
  {
    id: 'act-complete',
    title: 'ACT Complete Prep',
    description: 'Full preparation across all four ACT sections — English, Math, Reading, and Science — with a unified strategy for maximizing your composite score.',
    topics: ['Full-length practice tests', 'Section-by-section analysis', 'Time management strategies', 'Composite score optimization', 'Test day preparation'],
  },
  {
    id: 'act-english',
    title: 'ACT English',
    description: 'Master grammar, punctuation, sentence structure, and rhetorical skills tested in the ACT English section.',
    topics: ['Grammar & usage', 'Punctuation', 'Sentence structure', 'Rhetorical skills', 'Strategy & organization'],
  },
  {
    id: 'act-math',
    title: 'ACT Math',
    description: 'Cover all ACT Math content areas from pre-algebra to trigonometry, with emphasis on speed, accuracy, and problem-solving shortcuts.',
    topics: ['Pre-algebra & algebra', 'Geometry', 'Coordinate geometry', 'Trigonometry', 'Problem-solving strategies'],
  },
  {
    id: 'act-science',
    title: 'ACT Science',
    description: 'Learn to quickly interpret data, evaluate experiments, and analyze conflicting viewpoints — the core skills tested in the ACT Science section.',
    topics: ['Data representation', 'Research summaries', 'Conflicting viewpoints', 'Graph & table analysis', 'Scientific reasoning'],
  },
];
---

<Layout title="ACT Prep Tutoring — English, Math, Science & Complete" description="Expert 1-on-1 ACT prep tutoring. English, Math, Science sections or complete ACT preparation. Proven strategies. $18/hr. Free demo.">

  <!-- Hero -->
  <section class="relative bg-linear-to-b from-primary/5 to-white py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px]"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-flex items-center gap-2 bg-primary/10 text-primary font-semibold text-sm uppercase tracking-wider px-4 py-1.5 rounded-full mb-6">
          ACT Prep · $18/hr
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mt-3 mb-6 text-gray-900">
          Boost Your ACT Score with <span class="gradient-text">1-on-1 Tutoring</span>
        </h1>
        <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto mb-8">
          Our ACT tutors teach content, strategy, and time management for every section. Get personalized prep that targets your specific areas for improvement.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={siteConfig.app.bookDemo} class="group inline-flex items-center gap-2 bg-primary hover:bg-primary-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all shadow-lg shadow-primary/25">
            Book Free ACT Demo
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/pricing" class="inline-flex items-center gap-2 border-2 border-gray-300 hover:border-primary text-gray-700 hover:text-primary px-8 py-4 rounded-xl font-semibold text-lg transition-all">
            View Pricing
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ACT Sections -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">ACT Prep <span class="gradient-text">Programs</span></h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {sections.map((section) => (
          <div id={section.id} class="bg-gray-50 border border-gray-200 rounded-2xl p-7 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all scroll-mt-24">
            <h3 class="text-lg font-bold text-gray-900 mb-3">{section.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{section.description}</p>
            <div class="space-y-2">
              {section.topics.map((topic) => (
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  <span class="text-sm text-gray-700">{topic}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactForm title="Start Your ACT Prep Today" subtitle="Book a free demo and see how our tutors help students reach their target composite score." />

</Layout>
