---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/config';
import ContactForm from '../components/ContactForm.astro';

const sections = [
  {
    id: 'psat-reading-writing',
    title: 'PSAT Evidence-Based Reading & Writing',
    description: 'Develop strong reading comprehension and writing skills with targeted practice on passage analysis, grammar, and rhetoric.',
    topics: ['Reading comprehension', 'Command of evidence', 'Words in context', 'Standard English conventions', 'Expression of ideas'],
  },
  {
    id: 'psat-math',
    title: 'PSAT Math',
    description: 'Master algebra, problem-solving, data analysis, and advanced math concepts tested on the PSAT.',
    topics: ['Heart of Algebra', 'Problem Solving & Data Analysis', 'Passport to Advanced Math', 'Calculator strategies'],
  },
  {
    id: 'psat-nmsqt',
    title: 'PSAT/NMSQT Complete',
    description: 'Comprehensive preparation for the PSAT/NMSQT — the pathway to National Merit Scholarships and a strong SAT foundation.',
    topics: ['Full-length practice tests', 'National Merit qualifying strategies', 'Score analysis & improvement plan', 'SAT readiness building'],
  },
];
---

<Layout title="PSAT Prep Tutoring — Reading, Math & NMSQT" description="Expert 1-on-1 PSAT/NMSQT prep tutoring. Build SAT readiness and qualify for National Merit Scholarships. $18/hr. Free demo.">

  <!-- Hero -->
  <section class="relative bg-linear-to-b from-primary/5 to-white py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px]"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-flex items-center gap-2 bg-primary/10 text-primary font-semibold text-sm uppercase tracking-wider px-4 py-1.5 rounded-full mb-6">
          PSAT / NMSQT · $18/hr
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mt-3 mb-6 text-gray-900">
          Prepare for the PSAT and <span class="gradient-text">National Merit</span>
        </h1>
        <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto mb-8">
          The PSAT is your first step toward the SAT and National Merit Scholarships. Our 1-on-1 tutors help students build a strong foundation and achieve qualifying scores.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={siteConfig.app.bookDemo} class="group inline-flex items-center gap-2 bg-primary hover:bg-primary-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all shadow-lg shadow-primary/25">
            Book Free PSAT Demo
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/pricing" class="inline-flex items-center gap-2 border-2 border-gray-300 hover:border-primary text-gray-700 hover:text-primary px-8 py-4 rounded-xl font-semibold text-lg transition-all">
            View Pricing
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PSAT Sections -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">PSAT Prep <span class="gradient-text">Programs</span></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {sections.map((section) => (
          <div id={section.id} class="bg-gray-50 border border-gray-200 rounded-2xl p-7 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all scroll-mt-24">
            <h3 class="text-lg font-bold text-gray-900 mb-3">{section.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{section.description}</p>
            <div class="space-y-2">
              {section.topics.map((topic) => (
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  <span class="text-sm text-gray-700">{topic}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <ContactForm title="Start Your PSAT Prep Today" subtitle="Book a free demo and take the first step toward National Merit and SAT readiness." />

</Layout>
